{
  "name": "@openleash/desktop-client",
  "version": "0.36.10",
  "description": "OpenLeash desktop agent policy and attention client.",
  "author": "OpenLeash",
  "type": "commonjs",
  "main": "dist/main.js",
  "bin": {
    "openleash": "dist/cli/cli.js",
    "openleash-client": "dist/cli/cli.js",
    "openleash-agent": "dist/cli/cli.js"
  },
  "scripts": {
    "cli": "tsx src/cli/cli.ts",
    "dev": "npm run build && env -u ELECTRON_RUN_AS_NODE electron .",
    "build": "tsc -p tsconfig.json && node src/copy-assets.mjs && node src/build-native-island.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/proxy-manager.test.ts src/plugin-container-manager.test.ts src/local-plugin-runtime.test.ts src/agent-registry.test.ts",
    "test:island:mac": "node scripts/verify-native-island.mjs",
    "verify:release-dependencies": "node scripts/verify-release-dependencies.mjs"
  },
  "dependencies": {
    "@openleash/shared": "0.1.0",
    "better-sqlite3": "^12.10.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "electron": "^40.10.6",
    "electron-builder": "26.15.3",
    "sharp": "0.34.5",
    "simple-icons": "^16.19.0",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3"
  }
}
