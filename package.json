{
  "name": "@openleash/desktop-client",
  "version": "0.35.0",
  "type": "commonjs",
  "main": "dist/main.js",
  "bin": {
    "openleash": "dist/cli/cli.js",
    "openleash-client": "dist/cli/cli.js",
    "openleash-agent": "dist/cli/cli.js"
  },
  "scripts": {
    "cli": "tsx src/cli/cli.ts",
    "dev": "npm run build && env -u ELECTRON_RUN_AS_NODE electron .",
    "build": "tsc -p tsconfig.json && node src/copy-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@openleash/shared": "0.1.0",
    "better-sqlite3": "^12.10.0",
    "commander": "^12.1.0",
    "electron": "^33.4.11"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
